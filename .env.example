# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ALLOWED_DOMAIN=muze.co.th

# Session signing secret - generate with: openssl rand -hex 32
SESSION_SECRET=

# Daily Planner - shared secret the external daily-generation job sends as the
# X-Planner-Secret header when POSTing that day's schedule to /api/planner
PLANNER_SECRET=

PORT=3000

# MTS Customer Support dashboard — reads the Jira->Sheet export (see
# mae-thongsuk-dashboard/ Apps Script). Grant the service account below
# Viewer access on the sheet itself.
MTSCS_SHEET_ID=
MTSCS_SHEET_RANGE=JiraData!A:Z
# Base64-encoded service account JSON (production). Locally, falls back to
# ./google-sheets-credentials.json if this is unset.
GOOGLE_SHEETS_CREDENTIALS_BASE64=
# Optional — turns ticket keys in the table into links to Jira
JIRA_BASE_URL=
